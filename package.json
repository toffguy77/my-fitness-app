{
  "name": "burcev-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:api": "npm run dev --workspace=apps/api",
    "build": "npm run build --workspaces",
    "build:web": "npm run build --workspace=apps/web",
    "build:api": "npm run build --workspace=apps/api",
    "test": "npm run test --workspaces --if-present",
    "test:web": "npm run test --workspace=apps/web",
    "test:api": "cd apps/api && make test",
    "test:coverage": "npm run test:coverage:web && npm run test:coverage:api",
    "test:coverage:web": "npm run test:coverage --workspace=apps/web",
    "test:coverage:api": "cd apps/api && make test-coverage",
    "test:coverage:ci": "npm run test:coverage:ci --workspace=apps/web && cd apps/api && make test-coverage-ci",
    "lint": "npm run lint --workspaces --if-present",
    "lint:web": "npm run lint --workspace=apps/web",
    "lint:api": "cd apps/api && make lint",
    "type-check": "npm run type-check --workspaces --if-present",
    "prepare": "husky install",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:build": "docker-compose build",
    "docker:logs": "docker-compose logs -f",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:staging": "E2E_BASE_URL=https://new.burcev.team playwright test"
  },
  "overrides": {
    "serialize-javascript": "7.0.3",
    "rollup": "2.80.0",
    "minimatch": "10.2.4",
    "tar": "7.5.10",
    "jspdf": "4.2.0",
    "ajv": "8.18.0",
    "dompurify": "3.3.2",
    "lodash": "4.17.23"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "concurrently": "^8.2.2",
    "dotenv": "^17.3.1",
    "husky": "^9.0.11",
    "turbo": "^2.3.3"
  }
}
